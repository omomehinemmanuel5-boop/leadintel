# Required — the app fails closed (denies all access) if these are unset.
# This is a single-user Basic Auth gate, not a real multi-tenant auth
# system. Replace with NextAuth.js once real persistence (Volume VI) is
# in place and multiple people need their own accounts.
ADMIN_USER=
ADMIN_PASSWORD=

# --- Optional data providers ---
# Unset = pipeline falls back to demo data / free connectors only.
# Nothing breaks if these are missing — see src/lib/providers/config.ts

# Apollo.io — real name+email database match. Requires a paid plan with
# API access (their cheapest API-enabled tier is ~$59/mo as of writing).
# Each enrichment call (not the search) consumes a credit, capped at 5
# per pipeline run — see APOLLO_MATCH_LIMIT in src/lib/providers/apollo.ts.
APOLLO_API_KEY=

# Google Custom Search JSON API — free tier, 100 queries/day. Used only
# to read a company's OWN site (domain fallback + leadership page
# discovery), never third-party platforms. Get both values from
# https://programmablesearchengine.google.com/ (create a search engine
# scoped to "search the entire web") and
# https://console.cloud.google.com/apis/credentials (enable "Custom
# Search API" on the same project, create an API key).
GOOGLE_API_KEY=
GOOGLE_CSE_ID=

# Australian Business Register — free, but requires registering for a
# GUID (same-day email registration, not a purchase, no cost ever):
# https://abr.business.gov.au/Tools/AbrApi
# Company universe only — ABR does not expose director/officer data.
ABR_GUID=

# --- Persistence: suppression list (Edge Config) ---
# Native Vercel product, not a third-party marketplace integration —
# provisioned without any dashboard step. EDGE_CONFIG is a read-only
# connection string scoped to one store (safe to embed). The other two
# are needed for writes and are a disclosed tradeoff — see
# src/lib/suppressionStore.ts for the full reasoning.
EDGE_CONFIG=
EDGE_CONFIG_ID=
EDGE_CONFIG_WRITE_TOKEN=
EDGE_CONFIG_TEAM_ID=

# --- Not yet used, reserved for the next infra step ---
# Once a Postgres database is provisioned (Vercel Storage tab -> Neon,
# or Supabase's free tier), its connection string will go here and
# src/lib/store.ts will be swapped from in-memory to real queries.
# POSTGRES_URL=
